# API Configuration
API_TITLE="ECHR Dashboard API"
API_VERSION="1.0.0"
DEBUG=False

# Database Configuration
# SQLite (default, for development)
DATABASE_URL="sqlite:///./echr_dashboard.db"

# PostgreSQL (uncomment for production)
# DATABASE_URL="postgresql://user:password@localhost:5432/echr_dashboard"

SQLALCHEMY_ECHO=False

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:8000"]

# ECHR Extractor Configuration
ECHR_MAX_RETRIES=3
ECHR_TIMEOUT=30
ECHR_DEFAULT_LANGUAGE="ENG"

# Background Task Configuration
BACKGROUND_TASKS_ENABLED=True
TASK_QUEUE_MAX_SIZE=100

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# Logging
LOG_LEVEL="INFO"
