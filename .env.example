# ECHR Dashboard API Configuration Example
# Copy this file to .env and customize for your environment

# API Configuration
API_TITLE="ECHR Dashboard API"
API_VERSION="1.0.0"
DEBUG=False

# Database Configuration
# For SQLite (development - default)
DATABASE_URL="sqlite:///./echr_dashboard.db"

# For PostgreSQL (production)
# DATABASE_URL="postgresql://username:password@localhost:5432/echr_dashboard"

SQLALCHEMY_ECHO=False

# CORS Configuration
# Add your frontend URLs here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:8000"]

# ECHR Extractor Configuration
ECHR_MAX_RETRIES=3
ECHR_TIMEOUT=30
ECHR_DEFAULT_LANGUAGE="ENG"

# Background Task Configuration
BACKGROUND_TASKS_ENABLED=True
TASK_QUEUE_MAX_SIZE=100

# Pagination Defaults
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# Logging
LOG_LEVEL="INFO"
# LOG_LEVEL="DEBUG" for development
